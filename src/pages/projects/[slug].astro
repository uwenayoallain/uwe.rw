---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
import { Image } from "astro:assets";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} | UWENAYO Alain Pacifique`}>
  <div class='progress-container'>
    <div class='progress-bar'></div>
  </div>

  <article class='project-detail section'>
    <div class='post-header'>
      <a href='/works' class='back-link font-mono text-muted'>
        <span class='arrow'>&larr;</span> Back to Works
      </a>
      <div class='meta font-mono text-muted'>
        <span class='year'>{project.year}</span>
        <span class='separator'>/</span>
        <span class='category'>{project.category}</span>
      </div>
      <h1 class='title text-display split-text'>{project.title}</h1>
    </div>

    {
      project.image && (
        <div class='hero-image-wrapper'>
          <Image
            src={project.image.light}
            alt={project.title}
            class='hero-image light-mode-image'
            width={900}
          />
          <Image
            src={project.image.dark}
            alt={project.title}
            class='hero-image dark-mode-image'
            width={900}
          />
        </div>
      )
    }

    <div class='content-wrapper'>
      <div class='content'>
        {project.technologies && project.technologies.length > 0 && (
          <div class='tech-stack'>
            {project.technologies.map((tech) => (
              <span class='tech-tag'>{tech}</span>
            ))}
          </div>
        )}

        {project.role && (
          <div class='project-role'>
            <span class='role-label'>Role</span>
            <span class='role-value'>{project.role}</span>
          </div>
        )}

        <h2>Overview</h2>
        <p>{project.description}</p>
        <p>{project.content}</p>

        <div class='project-links'>
          {
            project.liveUrl && (
              <a
                href={project.liveUrl}
                target='_blank'
                rel='noopener noreferrer'
                class='link-btn primary'>
                Visit Live Site <span class='arrow-icon'>↗</span>
              </a>
            )
          }
          {
            project.repoUrl && (
              <a
                href={project.repoUrl}
                target='_blank'
                rel='noopener noreferrer'
                class='link-btn secondary'>
                View Code <span class='github-icon'>⌘</span>
              </a>
            )
          }
        </div>
      </div>
    </div>
  </article>
</Layout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { animateHeroText } from "../../lib/animations.js";

  gsap.registerPlugin(ScrollTrigger);

  function initProjectDetail() {
    gsap.to(".progress-bar", {
      scaleX: 1,
      ease: "none",
      scrollTrigger: {
        trigger: "body",
        start: "top top",
        end: "bottom bottom",
        scrub: 0.3,
      },
    });

    animateHeroText(".split-text");

    const heroImage = document.querySelector(".hero-image");
    if (heroImage) {
      gsap.to(heroImage, {
        yPercent: 30,
        ease: "none",
        scrollTrigger: {
          trigger: ".hero-image-wrapper",
          start: "top bottom",
          end: "bottom top",
          scrub: true,
        },
      });
    }

    const contentElements = document.querySelectorAll(".content > *");
    if (contentElements.length > 0) {
      gsap.to(contentElements, {
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.05,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ".content",
          start: "top 85%",
        },
      });
    }

    gsap.to([".back-link", ".meta"], {
      y: 0,
      opacity: 1,
      duration: 0.8,
      stagger: 0.1,
      ease: "power2.out",
      delay: 0.1,
      clearProps: "transform",
    });
  }

  document.addEventListener("astro:page-load", initProjectDetail);
</script>

<style>
  .progress-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    z-index: 1000;
    pointer-events: none;
  }

  .progress-bar {
    height: 100%;
    background: var(--color-brand-gold);
    width: 100%;
    transform: scaleX(0);
    transform-origin: left;
  }

  .project-detail {
    padding-top: var(--space-2xl);
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
    padding-bottom: var(--space-2xl);
  }

  .post-header {
    margin-bottom: var(--space-2xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Prevent FOUSC */
  :global(.js) .back-link,
  :global(.js) .meta,
  :global(.js) .content > * {
    opacity: 0;
  }
  
  :global(.js) .back-link,
  :global(.js) .meta {
    transform: translateY(-20px);
  }
  
  :global(.js) .content > * {
    transform: translateY(30px);
  }

  .back-link {
    align-self: center;
    margin-bottom: var(--space-xl);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
    padding: 8px 16px;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.03);
  }

  .back-link:hover {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .meta {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    margin-bottom: var(--space-lg);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.7;
  }

  .title {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-lg);
    text-wrap: balance;
  }

  .hero-image-wrapper {
    margin-bottom: var(--space-2xl);
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 21/9;
    position: relative;
    width: 100%;
    max-width: 900px;
  }

  .hero-image {
    width: 100%;
    height: 130%;
    object-fit: cover;
    position: relative;
    top: -10%;
  }

  .content-wrapper {
    max-width: 720px;
    margin: 0 auto;
  }

  .content {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-xl);
  }

  .tech-tag {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 6px 16px;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    color: var(--color-text-muted);
    transition: all 0.3s ease;
  }

  .tech-tag:hover {
    border-color: var(--color-brand-gold);
    color: var(--color-brand-gold);
  }

  .project-role {
    display: flex;
    gap: var(--space-md);
    align-items: baseline;
    padding: var(--space-md) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-xl);
  }

  .role-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .role-value {
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-text);
  }

  .content h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .content h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .content p {
    margin-bottom: var(--space-lg);
  }

  .project-links {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    flex-wrap: wrap;
  }

  .link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 12px 24px;
    border-radius: 100px;
    font-size: var(--text-base);
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 1px solid transparent;
  }

  .link-btn.primary {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .link-btn.primary:hover {
    background: var(--color-text-muted);
    transform: translateY(-2px);
  }

  .link-btn.secondary {
    background: transparent;
    border-color: var(--color-border);
    color: var(--color-text);
  }

  .link-btn.secondary:hover {
    border-color: var(--color-text);
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-2px);
  }

  .arrow-icon,
  .github-icon {
    font-family: system-ui; /* simple fix to ensure icon rendering */
  }
</style>
