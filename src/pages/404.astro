---
import Layout from "../layouts/Layout.astro";
---

<Layout title='404 - Lost in the Void'>
  <div class='error-page'>
    <div class='content-wrapper'>
      <h1 class='error-code font-mono' data-text='404'>404</h1>
      <p class='message text-display'>LOST IN THE VOID</p>
      <p class='description text-muted'>
        The page you are looking for has drifted into the digital abyss.
      </p>

      <a href='/' class='home-btn magnetic-link'>
        <span class='btn-text font-mono'>RETURN HOME</span>
      </a>
    </div>
  </div>
</Layout>

<style>
  .error-page {
    min-height: calc(100vh - 150px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: var(--space-xl);
  }

  .error-code {
    font-size: clamp(8rem, 20vw, 15rem);
    line-height: 0.8;
    font-weight: 700;
    position: relative;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  /* Glitch Effect */
  .error-code::before,
  .error-code::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-bg);
  }

  .error-code::before {
    left: 2px;
    text-shadow: -1px 0 var(--color-brand-gold);
    clip-path: inset(10% 0 85% 0);
    animation: glitch-anim-2 3s infinite linear alternate-reverse;
  }

  .home-btn {
    display: inline-flex;
    margin-top: var(--space-xl);
    padding: var(--space-sm) var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    background: transparent;
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.3s var(--ease-out-expo);
  }

  .home-btn:hover {
    background: var(--color-text);
    color: var(--color-bg);
    transform: translateY(-2px);
  }

  .error-code::after {
    left: -2px;
    text-shadow: -1px 0 var(--color-brand-navy);
    clip-path: inset(80% 0 10% 0);
    animation: glitch-anim 2.5s infinite linear alternate-reverse;
  }

  /* Modernized Keyframes using clip-path */
  @keyframes glitch-anim {
    0% {
      clip-path: inset(10% 0 80% 0);
    }
    20% {
      clip-path: inset(30% 0 10% 0);
    }
    40% {
      clip-path: inset(80% 0 5% 0);
    }
    60% {
      clip-path: inset(5% 0 90% 0);
    }
    80% {
      clip-path: inset(40% 0 20% 0);
    }
    100% {
      clip-path: inset(15% 0 60% 0);
    }
  }

  @keyframes glitch-anim-2 {
    0% {
      clip-path: inset(60% 0 10% 0);
    }
    20% {
      clip-path: inset(10% 0 85% 0);
    }
    40% {
      clip-path: inset(40% 0 30% 0);
    }
    60% {
      clip-path: inset(5% 0 60% 0);
    }
    80% {
      clip-path: inset(80% 0 5% 0);
    }
    100% {
      clip-path: inset(20% 0 50% 0);
    }
  }
</style>
