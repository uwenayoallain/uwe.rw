---
import ThemeToggle from "./ThemeToggle.astro";
---

<nav class='navbar'>
  <div class='container'>
    <div class='nav-content'>
      <a href='/' class='logo magnetic-link'>UWE.RW</a>

      <div class='nav-links'>
        <a href='/works' class='nav-link magnetic-link'>Works</a>
        <a href='/services' class='nav-link magnetic-link'>Services</a>
        <a href='/about' class='nav-link magnetic-link'>About</a>
        <a href='/blog' class='nav-link magnetic-link'>Blog</a>
        <div class="desktop-theme-toggle">
          <ThemeToggle />
        </div>
      </div>

      <div class='nav-right-mobile'>
        <ThemeToggle />
        <button class='menu-toggle' aria-label='Toggle Menu'>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  let scrollHandler: (() => void) | null = null;

  function cleanupNavbar() {
    if (scrollHandler) {
      window.removeEventListener("scroll", scrollHandler);
      scrollHandler = null;
    }
  }

  function initNavbar() {
    cleanupNavbar();

    const navbar = document.querySelector(".navbar") as HTMLElement;
    if (!navbar) return;

    let lastScroll = window.scrollY;
    const scrollThreshold = 10;

    scrollHandler = () => {
      const currentScroll = window.scrollY;
      const scrollDelta = currentScroll - lastScroll;
      const isScrolled = currentScroll > 50;

      if (isScrolled) {
        navbar.classList.add("scrolled");
      } else {
        navbar.classList.remove("scrolled");
      }

      if (isScrolled && scrollDelta > scrollThreshold) {
        navbar.classList.add("nav-hidden");
      } else if (scrollDelta < -scrollThreshold || currentScroll < 50) {
        navbar.classList.remove("nav-hidden");
      }

      lastScroll = currentScroll;
    };

    scrollHandler();
    window.addEventListener("scroll", scrollHandler, { passive: true });

    const menuToggle = document.querySelector(".menu-toggle");
    const navLinks = document.querySelector(".nav-links");

    if (menuToggle && navLinks) {
      const newMenuToggle = menuToggle.cloneNode(true);
      menuToggle.parentNode?.replaceChild(newMenuToggle, menuToggle);

      newMenuToggle.addEventListener("click", () => {
        navLinks.classList.toggle("active");
        (newMenuToggle as HTMLElement).classList.toggle("active");
      });
    }
  }

  document.addEventListener("astro:page-load", initNavbar);
  document.addEventListener("astro:before-swap", cleanupNavbar);
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding: var(--space-md) 0;
    transition: transform 0.5s var(--ease-out-expo),
                padding 0.5s var(--ease-out-expo);
  }

  .navbar.nav-hidden {
    transform: translateY(-150%);
  }

  .navbar.scrolled {
    padding: var(--space-sm) var(--space-md);
  }

  .nav-content {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 0;
    border: 1px solid transparent;
    border-radius: 0;
    background: transparent;
    transition: background 0.5s var(--ease-out-expo),
                border-radius 0.5s var(--ease-out-expo),
                border-color 0.5s var(--ease-out-expo),
                box-shadow 0.5s var(--ease-out-expo),
                padding 0.5s var(--ease-out-expo),
                max-width 0.5s var(--ease-out-expo);
  }

  .navbar.scrolled .nav-content {
    max-width: fit-content;
    margin: 0 auto;
    padding: var(--space-xs) var(--space-md);
    border-radius: 100px;
    background: var(--color-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-glass-border);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
  }

  .navbar:not(.scrolled) {
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
  }

  .logo {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: var(--space-md);
    align-items: center;
    margin-left: auto;
  }

  .desktop-theme-toggle {
    display: flex;
    align-items: center;
    margin-left: var(--space-sm);
  }

  .nav-link {
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    position: relative;
    padding: 0.5rem 0;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }

  .nav-link:hover {
    opacity: 1;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-text);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .nav-right-mobile {
    display: none;
    align-items: center;
    gap: var(--space-sm);
    margin-left: auto;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }

  .menu-toggle span {
    width: 24px;
    height: 2px;
    background-color: var(--color-text);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
      position: absolute;
      top: calc(100% + 10px);
      left: var(--space-md);
      right: var(--space-md);
      width: auto;
      margin-left: 0;
      background: var(--color-bg);
      flex-direction: column;
      padding: var(--space-md);
      border-radius: var(--radius-md);
      border: 1px solid var(--color-border);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }

    .nav-links.active {
      display: flex;
    }

    .desktop-theme-toggle {
      display: none;
    }

    .nav-right-mobile {
      display: flex;
    }

    .menu-toggle {
      display: flex;
    }
  }
</style>
