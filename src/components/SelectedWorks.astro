---
import { projects } from "../data/projects";
import { Image } from "astro:assets";
---

<section id='works' class='section selected-works'>
  <div class='container'>
    <div class='section-header fade-up'>
      <h2 class='section-title'>Selected Works</h2>
      <a href='/works' class='view-all-link group'>
        <span>View All Projects</span>
        <svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' class='arrow-icon'><line x1='5' y1='12' x2='19' y2='12'></line><polyline points='12 5 19 12 12 19'></polyline></svg>
      </a>
    </div>

    <div class='projects-grid'>
      {
        projects.map((project) => (
          <a href={`/projects/${project.slug}`} class='project-card'>
            <div class='project-image-container'>
              <Image
                src={project.image.light}
                alt={project.title}
                class='project-image light-mode-image'
                width={600}
                loading="lazy"
              />
              <Image
                src={project.image.dark}
                alt={project.title}
                class='project-image dark-mode-image'
                width={600}
                loading="lazy"
              />
              <div class='project-overlay'>
                <span class='view-project'>View Project</span>
              </div>
            </div>
            <div class='project-info'>
              <div class='project-header'>
                <h3 class='project-title'>{project.title}</h3>
                <span class='project-year'>{project.year}</span>
              </div>
              <p class='project-category'>{project.category}</p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .selected-works {
    padding: var(--space-3xl) 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .view-all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-base);
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.4s var(--ease-out-expo);
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: var(--font-mono);
  }

  .view-all-link:hover {
    background: var(--color-text);
    color: var(--color-bg);
    transform: translateY(-2px);
  }

  .arrow-icon {
    transition: transform 0.4s var(--ease-out-expo);
  }

  .view-all-link:hover .arrow-icon {
    transform: translateX(4px);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3xl) var(--space-2xl);
    padding-top: var(--space-xl);
  }

  .project-card:nth-child(even) {
    margin-top: 15vh;
  }

  .project-card {
    display: block;
    text-decoration: none;
    color: var(--color-text);
    transition: opacity 0.5s var(--ease-out-expo);
  }
  
  .projects-grid:hover .project-card:not(:hover) {
    opacity: 0.3;
    filter: grayscale(100%);
  }

  .project-image-container {
    width: 100%;
    aspect-ratio: 0.8; /* high end editorial portrait aspect */
    overflow: hidden;
    margin-bottom: var(--space-md);
    background: var(--color-surface);
    position: relative;
    clip-path: inset(0 0 0 0);
    transition: clip-path 0.7s var(--ease-out-expo);
    will-change: clip-path;
  }

  .project-card:hover .project-image-container {
    clip-path: inset(2% 2% 2% 2%);
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s var(--ease-out-expo), filter 0.7s ease;
    filter: brightness(0.8) contrast(1.1);
    will-change: transform;
  }

  .project-card:hover .project-image {
    transform: scale(1.08);
    filter: brightness(1) contrast(1);
  }

  .project-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .view-project {
    color: var(--color-bg);
    background: var(--color-text);
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-weight: 600;
    padding: var(--space-sm) var(--space-md);
    border-radius: 100px;
    transform: translateY(20px) scale(0.9);
    transition: all 0.5s var(--ease-out-expo);
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .project-card:hover .view-project {
    transform: translateY(0) scale(1);
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .project-title {
    font-size: var(--text-2xl);
    font-weight: 500;
    margin: 0;
  }

  .project-year {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .project-category {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
      padding-top: var(--space-md);
    }
    
    .project-card:nth-child(even) {
      margin-top: 0;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-md);
    }

    .section-title {
      font-size: var(--text-2xl);
    }
  }
</style>
